
# Copy this file to .env and fill in your values. .env is gitignored.

# Required
BUCKET_NAME=your-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AccessKeyId
AWS_SECRET_ACCESS_KEY=SecretAccessKeyID

# Optional (only needed if you don't already have AWS credentials configured
# via `aws configure`, environment variables, or an IAM role)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Optional overrides
PREFIX=
DEST_DIR=
CONCURRENCY=5
MAX_RETRIES=3
